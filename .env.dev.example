# Template for .env.dev, the environment file for the live-reloading dev Docker
# Compose stack. The `make compose/live` and `make compose/build` targets copy
# this file to .env.dev if that file does not already exist, then run:
#
#   docker compose --env-file .env.dev -f docker-compose.dev.yml up
#
# .env.dev is gitignored, so edit your copy freely; this .example file is the
# checked-in default.
#
# This separate env file exists so the dev stack has its OWN interpolation source
# and does NOT pick up values from a local ./.env (which is meant for `ims serve`
# run directly on your machine). Docker Compose auto-loads ./.env unless it is
# given an explicit --env-file, which is why the Makefile targets pass this one.
#
# Every variable below is optional: with them all commented out, the dev stack
# uses the defaults baked into docker-compose.dev.yml. Uncomment and edit any of
# these to override.

# IMS database name / credentials.
#IMS_DB_DATABASE="ims"
#IMS_DB_USER_NAME="ims"
IMS_DB_PASSWORD="replace_with_secure_random"

IMS_JWT_SECRET="replace_with_secure_random"

# Clubhouse (DMS) database name / credentials.
#IMS_DMS_DATABASE="rangers"
#IMS_DMS_USERNAME="clubhouseuser"
IMS_DMS_PASSWORD="replace_with_secure_random"

# Host port to expose the server on (http://localhost:<port>/ims/app).
#IMS_HOST_PORT=8080
