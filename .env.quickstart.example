# Template for .env.quickstart, the environment file for the quickstart Docker
# Compose stack. The `make compose/quickstart` target copies this file to
# .env.quickstart if that file does not already exist, then runs:
#
#   docker compose --env-file .env.quickstart -f docker-compose.quickstart.yml up
#
# .env.quickstart is gitignored, so edit your copy freely; this .example file is
# the checked-in default.
#
# This separate env file exists so the quickstart stack has its OWN interpolation
# source and does NOT pick up values from a local ./.env (which is meant for
# `ims serve` run directly on your machine). Docker Compose auto-loads ./.env
# unless it is given an explicit --env-file, which is why the Makefile target
# passes this one.
#
# Every variable below is optional: with them all commented out, the quickstart
# stack uses the defaults baked into docker-compose.quickstart.yml. Uncomment and
# edit any of these to override.

# Handle of the bootstrap IMS administrator (must match the handle you pass to
# `ims add-user`). Defaults to QuickstartAdmin.
#IMS_ADMINS="QuickstartAdmin"

# IMS database name / credentials.
#IMS_DB_DATABASE="ims"
#IMS_DB_USER_NAME="ims"
IMS_DB_PASSWORD="replace_with_secure_random"

IMS_JWT_SECRET="replace_with_secure_random"

# Host port to expose the server on (http://localhost:<port>/ims/app).
#IMS_HOST_PORT=8080

# Docker image tag to build/run.
#IMAGE_TAG="latest"
